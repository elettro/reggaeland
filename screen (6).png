<!DOCTYPE html><html class="dark" lang="en"><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<link href="https://fonts.googleapis.com" rel="preconnect">
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect">
<link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;700;900&amp;family=Inter:wght@400;600;700&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "on-primary": "#003915",
                    "on-secondary-container": "#725f00",
                    "surface-container-low": "#1c1b1b",
                    "surface-container-high": "#2a2a2a",
                    "background": "#131313",
                    "on-secondary": "#3a3000",
                    "secondary-fixed": "#ffe16d",
                    "inverse-surface": "#e5e2e1",
                    "tertiary-fixed": "#ffdad5",
                    "tertiary-fixed-dim": "#ffb4a9",
                    "on-tertiary": "#690001",
                    "primary-fixed-dim": "#6add84",
                    "inverse-primary": "#006e2f",
                    "surface-container-highest": "#353534",
                    "error-container": "#93000a",
                    "on-surface-variant": "#bdcabb",
                    "on-primary-fixed": "#002109",
                    "on-error-container": "#ffdad6",
                    "outline": "#889486",
                    "on-tertiary-fixed": "#410000",
                    "on-error": "#690005",
                    "tertiary": "#ffb4a9",
                    "error": "#ffb4ab",
                    "on-tertiary-fixed-variant": "#930003",
                    "on-primary-fixed-variant": "#005322",
                    "on-primary-container": "#003111",
                    "primary": "#6add84",
                    "secondary-container": "#ffdb3c",
                    "on-surface": "#e5e2e1",
                    "surface-bright": "#3a3939",
                    "inverse-on-surface": "#313030",
                    "tertiary-container": "#ff5543",
                    "primary-fixed": "#87fb9d",
                    "on-tertiary-container": "#5c0001",
                    "secondary": "#fff9ef",
                    "on-secondary-fixed-variant": "#544600",
                    "surface-tint": "#6add84",
                    "primary-container": "#2da553",
                    "surface-variant": "#353534",
                    "surface-dim": "#131313",
                    "surface-container-lowest": "#0e0e0e",
                    "on-secondary-fixed": "#221b00",
                    "secondary-fixed-dim": "#e9c400",
                    "surface": "#131313",
                    "outline-variant": "#3e4a3e",
                    "surface-container": "#201f1f",
                    "on-background": "#e5e2e1"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "0.5rem",
                    "xl": "0.75rem",
                    "full": "9999px"
            },
            "fontFamily": {
                    "headline": ["Epilogue"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
        .glass-card {
            background: rgba(53, 53, 52, 0.6);
            backdrop-filter: blur(20px);
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
    </style>
</head>
<body class="bg-background text-on-surface font-body selection:bg-primary selection:text-on-primary" data-mode="connect">
<!-- Top Navigation Bar -->
<nav class="fixed top-0 w-full z-50 bg-[#353534]/60 backdrop-blur-xl flex justify-between items-center px-8 h-20 shadow-2xl shadow-black/10">
<div class="text-2xl font-black text-[#6add84] tracking-widest font-['Epilogue'] uppercase" style="">Reggae.Land</div>
<div class="hidden md:flex items-center space-x-8">
<a class="font-['Epilogue'] uppercase tracking-tighter text-[#e5e2e1] hover:text-[#6add84] hover:opacity-80 transition-all duration-300" href="#" style="">Stashbox</a>
<a class="font-['Epilogue'] uppercase tracking-tighter text-[#e5e2e1] hover:text-[#6add84] hover:opacity-80 transition-all duration-300" href="#" style="">Artist Spotlight</a>
<a class="font-['Epilogue'] uppercase tracking-tighter text-[#e5e2e1] hover:text-[#6add84] hover:opacity-80 transition-all duration-300" href="#" style="">Feed</a>
<a class="font-['Epilogue'] uppercase tracking-tighter text-[#6add84] border-b-2 border-[#6add84] pb-1 hover:opacity-80 transition-all duration-300" href="#" style="">Merch</a>
<a class="font-['Epilogue'] uppercase tracking-tighter text-[#e5e2e1] hover:text-[#6add84] hover:opacity-80 transition-all duration-300" href="#" style="">Shop</a>
</div>
<div class="flex items-center space-x-6">
<button class="material-symbols-outlined text-[#e5e2e1] hover:text-[#6add84] transition-colors" style="">shopping_bag</button>
<button class="bg-gradient-to-br from-[#6add84] to-[#2da553] text-on-primary font-bold px-6 py-2 rounded-lg active:scale-95 duration-200 transition-all uppercase tracking-tighter text-sm" style="">Subscribe</button>
</div>
</nav>
<!-- Side Navigation (Desktop Only) -->
<aside class="fixed left-0 top-0 h-full z-40 hidden lg:flex flex-col h-full w-64 border-r border-[#353534]/20 bg-[#131313] shadow-xl pt-24">
<div class="px-6 mb-8">
<div class="text-[#6add84] font-black uppercase font-['Epilogue'] text-xl" style="">Reggae.Land</div>
<div class="text-[#bdcabb] text-xs font-['Epilogue']" style="">The Sonic Canvas</div>
</div>
<nav class="flex-1 space-y-2">
<a class="flex items-center space-x-4 py-3 px-4 mx-2 text-[#bdcabb] hover:bg-[#353534]/50 hover:pl-6 transition-all duration-300 font-['Epilogue'] font-bold" href="#" style="">
<span class="material-symbols-outlined" style="">library_music</span>
<span class="" style="">Stashbox</span>
</a>
<a class="flex items-center space-x-4 py-3 px-4 mx-2 text-[#bdcabb] hover:bg-[#353534]/50 hover:pl-6 transition-all duration-300 font-['Epilogue'] font-bold" href="#" style="">
<span class="material-symbols-outlined" style="">star</span>
<span class="" style="">Artists</span>
</a>
<a class="flex items-center space-x-4 py-3 px-4 mx-2 text-[#bdcabb] hover:bg-[#353534]/50 hover:pl-6 transition-all duration-300 font-['Epilogue'] font-bold" href="#" style="">
<span class="material-symbols-outlined" style="">rss_feed</span>
<span class="" style="">Feed</span>
</a>
<a class="flex items-center space-x-4 py-3 px-4 bg-[#2da553] text-[#e5e2e1] rounded-lg mx-2 transition-all duration-300 font-['Epilogue'] font-bold" href="#" style="">
<span class="material-symbols-outlined" style="">shopping_bag</span>
<span class="" style="">Merch</span>
</a>
<a class="flex items-center space-x-4 py-3 px-4 mx-2 text-[#bdcabb] hover:bg-[#353534]/50 hover:pl-6 transition-all duration-300 font-['Epilogue'] font-bold" href="#" style="">
<span class="material-symbols-outlined" style="">storefront</span>
<span class="" style="">Shop</span>
</a>
</nav>
<div class="p-6 space-y-4 border-t border-[#353534]/20">
<a class="flex items-center space-x-4 text-[#bdcabb] hover:text-[#6add84] transition-colors font-['Epilogue'] font-bold" href="#" style="">
<span class="material-symbols-outlined" style="">settings</span>
<span class="" style="">Settings</span>
</a>
<a class="flex items-center space-x-4 text-[#bdcabb] hover:text-[#6add84] transition-colors font-['Epilogue'] font-bold" href="#" style="">
<span class="material-symbols-outlined" style="">help</span>
<span class="" style="">Support</span>
</a>
</div>
</aside>
<main class="lg:pl-64 pt-20">
<!-- Hero Section -->
<section class="relative h-[870px] flex items-center overflow-hidden">
<div class="absolute inset-0 z-0">
<img alt="Wear the Rhythm Lifestyle" class="w-full h-full object-cover grayscale-[40%] brightness-50" data-alt="group of trendy young adults wearing reggae inspired high-fashion streetwear in a sun-drenched outdoor urban setting with tropical plants" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC3BG4kmOBynNnMp_B87M8gem02FmgvAYt2O6vICss0vwh-0nqgJIIgMDoH5Sq1vfmnc4n64kWSQBz-18VZvztnQF-e7527ah-tk-4Sb6c9n0ztgRzP7WlhcrL-DR0_090GmCgTWC1dXliXmeUS_nF0TVctHM1YUK8CHo3G5JZtnjWLSa2IAzHHJ3blOsyrlHxOTuHvRS8UYu4wkFEtiwoNiBxXS6s7neDKNR5fLdR87EeTdTjXb6r5288KHoaRKFgvBiIj7tJdO_dJ" style="">
<div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent"></div>
</div>
<div class="relative z-10 px-8 md:px-16 max-w-4xl">
<h1 class="font-headline text-7xl md:text-9xl font-black uppercase leading-[0.85] tracking-tighter text-on-surface mb-8" style="">
                    Wear The<br><span class="text-primary" style="">Rhythm</span>
</h1>
<p class="text-xl md:text-2xl text-on-surface-variant max-w-xl mb-10 font-medium" style="">
                    Premium Stashbox apparel designed for the heavy bass and the golden highs. Culturally rooted, high-fashion execution.
                </p>
<div class="flex flex-wrap gap-4">
<button class="bg-gradient-to-r from-primary to-primary-container text-on-primary px-10 py-5 rounded-lg font-bold text-lg hover:scale-105 transition-transform" style="">Explore Drop 01</button>
<button class="bg-surface-container-highest/40 backdrop-blur-md border border-primary/20 text-on-surface px-10 py-5 rounded-lg font-bold text-lg hover:bg-surface-container-highest/60 transition-all" style="">View Lookbook</button>
</div>
</div>
</section>
<!-- Limited Edition Promo Banner -->
<section class="px-8 py-12">
<div class="bg-surface-container-high rounded-xl p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8 border border-outline-variant/10">
<div class="flex flex-col">
<span class="text-secondary-fixed-dim font-bold tracking-widest uppercase text-sm mb-2" style="">Exclusive Release</span>
<h2 class="font-headline text-4xl font-black uppercase text-on-surface" style="">Limited Edition Stashbox Drops</h2>
</div>
<div class="flex gap-6">
<div class="flex flex-col items-center">
<span class="text-4xl font-headline font-black text-primary" style="">02</span>
<span class="text-[10px] uppercase font-bold text-on-surface-variant" style="">Days</span>
</div>
<div class="text-4xl font-headline font-black text-on-surface-variant" style="">:</div>
<div class="flex flex-col items-center">
<span class="text-4xl font-headline font-black text-primary" style="">14</span>
<span class="text-[10px] uppercase font-bold text-on-surface-variant" style="">Hours</span>
</div>
<div class="text-4xl font-headline font-black text-on-surface-variant" style="">:</div>
<div class="flex flex-col items-center">
<span class="text-4xl font-headline font-black text-primary" style="">56</span>
<span class="text-[10px] uppercase font-bold text-on-surface-variant" style="">Mins</span>
</div>
</div>
<button class="bg-secondary-fixed-dim text-on-secondary px-8 py-4 rounded-lg font-bold uppercase tracking-tighter hover:bg-secondary-container transition-colors" style="">Notify Me</button>
</div>
</section>
<!-- Product Grid -->
<section class="px-8 py-20">
<div class="flex justify-between items-end mb-12">
<h2 class="font-headline text-5xl font-black uppercase" style="">The Essentials</h2>
<div class="flex gap-4">
<button class="bg-surface-container text-on-surface px-6 py-2 rounded-full text-sm font-bold border border-outline-variant/10" style="">Tees</button>
<button class="bg-surface-container text-on-surface px-6 py-2 rounded-full text-sm font-bold border border-outline-variant/10" style="">Hoodies</button>
<button class="bg-surface-container text-on-surface px-6 py-2 rounded-full text-sm font-bold border border-outline-variant/10" style="">Vinyl</button>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
<!-- Product 1 -->
<div class="group">
<div class="aspect-[4/5] overflow-hidden rounded-xl bg-surface-container mb-6 relative">
<img alt="Stashbox Classic Tee" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" data-alt="premium heavy cotton black oversized t-shirt with minimalist green reggae.land logo on chest studio shot on dark gray background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAnsgNc6EbC2v54iXGo0wSvSP5LyRTMYj5C8FjASGKMJl7QccwcNOSlDzNo_WM6malp9w-xcQutyB4-OUW46gGGqQYAaL69eRWKEqZH6wjfFPh0bIPWxK5roFCmTm0budMVFXtbImwGmL3WqXblIRwSBex77ny1R7jyJHVjuWCkaBdI3Eqpd385TjNNeuIJt7o9h3-oSHDhkNX73Y7K4y2qQQR0ytSPBvhUdhDW9jrpHhV_CIOxgPsO0wfC9hkeDkLGtjsyZ4xb02JP" style="">
<div class="absolute top-4 right-4 bg-tertiary-container text-on-tertiary-container text-[10px] font-black uppercase px-3 py-1 rounded-full" style="">New Drop</div>
</div>
<div class="flex justify-between items-start">
<div>
<h3 class="font-headline text-2xl font-bold uppercase mb-1" style="">Stashbox Classic Tee</h3>
<p class="text-on-surface-variant text-sm" style="">Heavyweight 240GSM Cotton</p>
</div>
<span class="text-secondary-fixed-dim font-black text-xl" style="">$45</span>
</div>
<button class="w-full mt-6 bg-surface-container-highest hover:bg-primary hover:text-on-primary py-4 rounded-lg font-bold transition-all flex items-center justify-center gap-2" style="">
<span class="material-symbols-outlined text-sm" style="">add_shopping_cart</span>
                        Add to Stash
                    </button>
</div>
<!-- Product 2 -->
<div class="group">
<div class="aspect-[4/5] overflow-hidden rounded-xl bg-surface-container mb-6 relative">
<img alt="Rhythm &amp; Soul Hoodie" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" data-alt="premium olive green hoodie with large artistic typography across the back high-end fashion streetwear product shot" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBP_QvVlBd2N3CwuR1rS_6mGo85iRRPfX3dcHSF9dreDmJ1RoAxK5bVrfB2_h5H6PlClW6xgN0-kML_fls1bY4lstTAwqbUPigp3YQ7G4PQjnekyg7s611odxu4vQuJj7lSXEHht4VB4loQB9yGlLPlkhWACtIjDFlDJXxZD7aQWLTEEGbLdYYhez8tU9BAitCzbJ7V0_6gBfVLDYv2Hg0oywptGGGWRO-IUlFb3NyhvzVyfFBv6j6Dd7zdbA_c5OpCxxs-nb7J1h0c" style="">
</div>
<div class="flex justify-between items-start">
<div>
<h3 class="font-headline text-2xl font-bold uppercase mb-1" style="">Rhythm &amp; Soul Hoodie</h3>
<p class="text-on-surface-variant text-sm" style="">Fleece Lined, Oversized Fit</p>
</div>
<span class="text-secondary-fixed-dim font-black text-xl" style="">$85</span>
</div>
<button class="w-full mt-6 bg-surface-container-highest hover:bg-primary hover:text-on-primary py-4 rounded-lg font-bold transition-all flex items-center justify-center gap-2" style="">
<span class="material-symbols-outlined text-sm" style="">add_shopping_cart</span>
                        Add to Stash
                    </button>
</div>
<!-- Product 3 -->
<div class="group">
<div class="aspect-[4/5] overflow-hidden rounded-xl bg-surface-container mb-6 relative">
<img alt="Sound System Cap" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" data-alt="high quality black corduroy baseball cap with embroidered golden reggae land logo on front professional product photography" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDrITQ1fb3NyjDYEFq2kvbaYCya-z136G6z9YobQ3EUGdFkpTzkiyek0h-Vze1NYtEqUwcUbelmOIe-fmoOvIDqh76ULK7kTeFiKny6wOP5rJ6fdUf_6dsE3TUlirMrCNEV4RHhSJEL7-JnwcdmQ5iepyQNtnUm1riA0AaHEklaxkmx3Vhh--KV92XF8-S2A23jQladsWhpk6efyh6YkVSyi9I14GKBU4Wj4Qz1L5xy2s5qg6O5nXjYRrsIe0tZblfIh4dIJNXC3-IS" style="">
</div>
<div class="flex justify-between items-start">
<div>
<h3 class="font-headline text-2xl font-bold uppercase mb-1" style="">Sound System Cap</h3>
<p class="text-on-surface-variant text-sm" style="">Corduroy with Gold Embroidery</p>
</div>
<span class="text-secondary-fixed-dim font-black text-xl" style="">$35</span>
</div>
<button class="w-full mt-6 bg-surface-container-highest hover:bg-primary hover:text-on-primary py-4 rounded-lg font-bold transition-all flex items-center justify-center gap-2" style="">
<span class="material-symbols-outlined text-sm" style="">add_shopping_cart</span>
                        Add to Stash
                    </button>
</div>
</div>
</section>
<!-- Lifestyle Section -->
<section class="px-8 py-20 bg-surface-container-lowest">
<div class="max-w-7xl mx-auto">
<div class="mb-16 text-center">
<h2 class="font-headline text-5xl md:text-7xl font-black uppercase mb-4 tracking-tighter" style="">Reggae.Land in the Wild</h2>
<p class="text-on-surface-variant max-w-2xl mx-auto" style=""><font color="#6add84">Worldwide</font></p>
</div>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
<div class="space-y-4 md:space-y-8">
<div class="rounded-xl overflow-hidden aspect-square grayscale hover:grayscale-0 transition-all duration-500">
<img alt="Fan in Merch" class="w-full h-full object-cover" data-alt="cool young woman wearing a reggae.land hoodie posing in a neon-lit urban alleyway at night aesthetic photo" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAHg9kxEKKVTrvd--SHWi4hHKLzJZTObocqkGTXRedUH4N5xpczhCA9IjW8cytlxIc90R_wzc2kpbiBa5_dJPnVoDQ7_SPX8DNFjfvmOBwhiN0SmUry2onZ77knzssM2BGQiTWiaf1kcEa5UNuHSKINDk7GbPEDJdYynGRrH19uzcd4Eker_hIEXLWB_35131VFhClOeE4gIPSdoJFJnjLxA36TxFgjj0O4Xainl-sS42lnJCWvETt0MUtWIsfNWbxznrgAAhzyVEQi" style="">
